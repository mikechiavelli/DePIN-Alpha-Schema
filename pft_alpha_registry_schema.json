            }
          }
        },
        "risks": {
          "type": "array",
          "items": { "$ref": "#/definitions/risk_item" }
        },
        "synergies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "analyst_note": { "type": "string", "minLength": 10 }
      }
    },

    "airdrop_rubric_scores": {
      "type": "object",
      "description": "8-factor scoring rubric v2. Four factors are INVERTED — lower raw score = better outcome for farmer. Composite formula: Score = (Value x 0.35) + (Confirm x 0.20) + (Prosp x 0.10) + ((6-Satur) x 0.10) + ((6-Sybil) x 0.10) + ((6-Cost) x 0.07) + ((6-Time) x 0.05) + (Unlock x 0.03)",
      "required": [
        "value_potential", "confirmation_signal", "retroactive_prospective",
        "wallet_saturation", "sybil_detection_risk", "cost_to_farm",
        "time_commitment", "unlock_schedule_risk"
      ],
      "additionalProperties": false,
      "properties": {
        "value_potential": {
          "type": "object",
          "description": "Weight: 35%. Rated 1-5. FDV comps, protocol valuation, prior benchmarks.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
