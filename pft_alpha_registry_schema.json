            "rationale":{ "type": "string" }
          }
        },
        "confirmation_signal": {
          "type": "object",
          "description": "Weight: 20%. Rated 1-5. Confirmed founder/CMO statement = 5; speculation = 1.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
            "weight":   { "type": "number", "const": 0.20 },
            "rationale":{ "type": "string" }
          }
        },
        "retroactive_prospective": {
          "type": "object",
          "description": "Weight: 10%. FORWARD score — 5 = fully farmable now; snapshot taken = 1.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
            "weight":   { "type": "number", "const": 0.10 },
            "rationale":{ "type": "string" }
          }
        },
        "wallet_saturation": {
          "type": "object",
          "description": "Weight: 10%. INVERTED — 5 = low saturation (good); 1 = extreme saturation.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
            "weight":   { "type": "number", "const": 0.10 },
            "rationale":{ "type": "string" }
          }
        },
        "sybil_detection_risk": {
          "type": "object",
          "description": "Weight: 10%. INVERTED — 5 = highest scrutiny (bad); 1 = minimal checks.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
            "weight":   { "type": "number", "const": 0.10 },
            "rationale":{ "type": "string" }
          }
        },
        "cost_to_farm": {
          "type": "object",
          "description": "Weight: 7%. INVERTED — 5 = nearly free; 1 = very expensive.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
            "weight":   { "type": "number", "const": 0.07 },
            "rationale":{ "type": "string" }
          }
        },
        "time_commitment": {
          "type": "object",
          "description": "Weight: 5%. INVERTED — 5 = minimal time; 1 = daily intensive engagement.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
            "score":    { "$ref": "#/definitions/score_1_5" },
            "weight":   { "type": "number", "const": 0.05 },
            "rationale":{ "type": "string" }
          }
        },
        "unlock_schedule_risk": {
          "type": "object",
          "description": "Weight: 3%. FORWARD score — 5 = favorable vesting; 1 = instant full unlock.",
          "required": ["score", "weight", "rationale"],
          "additionalProperties": false,
          "properties": {
