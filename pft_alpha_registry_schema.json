            "rationale":{ "type": "string" }
          }
        },
        "composite_formula_note": {
          "type": "string",
          "const": "Score = (Value x 0.35) + (Confirm x 0.20) + (Prosp x 0.10) + ((6-Satur) x 0.10) + ((6-Sybil) x 0.10) + ((6-Cost) x 0.07) + ((6-Time) x 0.05) + (Unlock x 0.03)"
        }
      }
    }

  },

  "oneOf": [
